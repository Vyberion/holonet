# OCI environment template for the Holonet web app.
# Copy this to .env.local on the OCI web checkout, then fill the values.

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
HOLONET_DEPLOY_BRANCH=migration

# Public site URLs.
NEXT_PUBLIC_SITE_URL=https://www.thesithorder.org
NEXT_PUBLIC_EMBED_ASSET_URL=https://www.thesithorder.org
HOLONET_COOKIE_DOMAIN=thesithorder.org

# Supabase production data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Roblox OAuth.
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=
# Optional override. Leave unset to use the current request host.
# ROBLOX_REDIRECT_URI=https://www.thesithorder.org/api/auth/callback

# Google Workspace export support.
# Prefer one JSON value if possible. Keep it on one line in .env.local.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Or use these instead of GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional, only needed when you enable the handbook refresh endpoint from OCI cron.
CRON_SECRET=
HANDBOOK_PDF_REFRESH_LIMIT=8

# Keep this false on OCI unless you intentionally add an OCI-only test mode later.
HOLONET_PREVIEW_SUPERUSER=false
